{
  "name": "unisism-ubs-backend",
  "version": "0.1.0",
  "description": "Backend da Face 1 (UBS) do sistema UNISISM — atendimento, encaminhamentos e PEC.",
  "main": "dist/main/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --exit-child src/main/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:seed": "ts-node-dev --transpile-only prisma/seed.ts",
    "minio:init": "ts-node-dev --transpile-only scripts/init-minio.ts",
    "db:setup-triggers": "ts-node-dev --transpile-only scripts/setup-db-triggers.ts",
    "tfd:rebuild-audit-chain": "ts-node-dev --transpile-only scripts/rebuild-tfd-audit-chain.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1035.0",
    "@aws-sdk/s3-request-presigner": "^3.1035.0",
    "@prisma/client": "^6.4.1",
    "bcryptjs": "^2.4.3",
    "clamscan": "^2.4.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "fast-csv": "^5.0.5",
    "helmet": "^8.0.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "node-forge": "^1.4.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.18.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "prom-client": "^15.1.3",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/clamscan": "^2.4.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.7.5",
    "@types/node-cron": "^3.0.11",
    "@types/node-forge": "^1.3.14",
    "@types/pdfkit": "^0.17.6",
    "@types/uuid": "^10.0.0",
    "prisma": "^6.4.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
