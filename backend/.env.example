# === Banco de dados ===
POSTGRES_USER=unisism
POSTGRES_PASSWORD=unisism
POSTGRES_DB=unisism_ubs
POSTGRES_PORT=5432
DATABASE_URL="postgresql://unisism:unisism@localhost:5432/unisism_ubs?schema=public"

# === HTTP ===
PORT=3333
BACKEND_PORT=3333
CORS_ORIGIN=http://localhost:5173

# === Auth ===
JWT_SECRET=troque-por-um-segredo-forte
JWT_REFRESH_SECRET=troque-por-um-refresh-forte
JWT_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# === Uploads ===
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=10

# === Runtime ===
NODE_ENV=development
LOG_LEVEL=info
